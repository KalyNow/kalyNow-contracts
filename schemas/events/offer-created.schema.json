{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.kalynow.com/events/offer-created.schema.json",
  "title": "OfferCreatedEvent",
  "description": "Published when a seller successfully creates a new offer on the kalyNow platform.",
  "type": "object",
  "required": ["eventId", "eventName", "occurredAt", "source", "payload"],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique event identifier (UUID v4)."
    },
    "eventName": {
      "type": "string",
      "const": "offer_created"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the event was produced."
    },
    "source": {
      "type": "string",
      "description": "Service that produced the event.",
      "example": "offer-service"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "Optional correlation ID for distributed tracing."
    },
    "payload": {
      "type": "object",
      "required": ["offerId", "sellerId", "title", "price", "category", "address", "tags", "createdAt"],
      "additionalProperties": false,
      "properties": {
        "offerId": { "type": "string", "format": "uuid" },
        "sellerId": { "type": "string", "format": "uuid" },
        "title": { "type": "string", "minLength": 1, "maxLength": 255 },
        "price": {
          "type": "object",
          "required": ["amount", "currency"],
          "properties": {
            "amount": { "type": "number", "minimum": 0 },
            "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "BRL"] }
          }
        },
        "category": {
          "type": "string",
          "enum": ["real_estate", "vehicle", "electronics", "furniture", "clothing", "services", "other"]
        },
        "address": {
          "type": "object",
          "required": ["street", "city", "state", "country", "postalCode"],
          "properties": {
            "street": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "country": { "type": "string" },
            "postalCode": { "type": "string" },
            "coordinates": {
              "type": "object",
              "required": ["latitude", "longitude"],
              "properties": {
                "latitude": { "type": "number" },
                "longitude": { "type": "number" }
              }
            }
          }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "examples": [
    {
      "eventId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "eventName": "offer_created",
      "occurredAt": "2024-06-01T12:00:00Z",
      "source": "offer-service",
      "correlationId": "f0e1d2c3-b4a5-6789-0fed-cba987654321",
      "payload": {
        "offerId": "11111111-1111-1111-1111-111111111111",
        "sellerId": "22222222-2222-2222-2222-222222222222",
        "title": "Cozy apartment in downtown",
        "price": { "amount": 250000, "currency": "USD" },
        "category": "real_estate",
        "address": {
          "street": "123 Main St",
          "city": "New York",
          "state": "NY",
          "country": "US",
          "postalCode": "10001",
          "coordinates": { "latitude": 40.7128, "longitude": -74.006 }
        },
        "tags": ["apartment", "downtown", "furnished"],
        "createdAt": "2024-06-01T12:00:00Z"
      }
    }
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.kalynow.com/events/offer-viewed.schema.json",
  "title": "OfferViewedEvent",
  "description": "Published when a user (or anonymous session) views an offer detail page.",
  "type": "object",
  "required": ["eventId", "eventName", "occurredAt", "source", "payload"],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventName": {
      "type": "string",
      "const": "offer_viewed"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "required": ["offerId", "sellerId", "sessionId", "platform", "viewedAt"],
      "additionalProperties": false,
      "properties": {
        "offerId": { "type": "string", "format": "uuid" },
        "sellerId": { "type": "string", "format": "uuid" },
        "viewerId": {
          "type": "string",
          "format": "uuid",
          "description": "The authenticated user who viewed the offer; absent for anonymous sessions."
        },
        "sessionId": {
          "type": "string",
          "description": "Anonymous session identifier."
        },
        "platform": {
          "type": "string",
          "enum": ["web", "ios", "android"]
        },
        "referrer": {
          "type": "string",
          "description": "Referral source, e.g. 'search', 'recommendation', 'direct'."
        },
        "viewedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "examples": [
    {
      "eventId": "c3d4e5f6-a7b8-9012-cdef-123456789012",
      "eventName": "offer_viewed",
      "occurredAt": "2024-06-03T14:22:00Z",
      "source": "offer-service",
      "payload": {
        "offerId": "11111111-1111-1111-1111-111111111111",
        "sellerId": "22222222-2222-2222-2222-222222222222",
        "viewerId": "44444444-4444-4444-4444-444444444444",
        "sessionId": "sess_abc123xyz",
        "platform": "web",
        "referrer": "search",
        "viewedAt": "2024-06-03T14:22:00Z"
      }
    }
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.kalynow.com/events/notification-opened.schema.json",
  "title": "NotificationOpenedEvent",
  "description": "Published when a recipient opens (taps or clicks) a notification on any channel.",
  "type": "object",
  "required": ["eventId", "eventName", "occurredAt", "source", "payload"],
  "additionalProperties": false,
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventName": {
      "type": "string",
      "const": "notification_opened"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "required": ["notificationId", "recipientId", "channel", "category", "openedAt"],
      "additionalProperties": false,
      "properties": {
        "notificationId": { "type": "string", "format": "uuid" },
        "recipientId": { "type": "string", "format": "uuid" },
        "channel": {
          "type": "string",
          "enum": ["push", "email", "sms", "in_app"]
        },
        "category": {
          "type": "string",
          "enum": ["offer_activity", "reservation", "account", "marketing", "system"]
        },
        "actionUrl": {
          "type": "string",
          "format": "uri",
          "description": "Deep-link or URL the notification directed the user to."
        },
        "openedAt": { "type": "string", "format": "date-time" },
        "timeToOpenMs": {
          "type": "integer",
          "minimum": 0,
          "description": "Milliseconds between delivery and open, used for engagement metrics."
        }
      }
    }
  },
  "examples": [
    {
      "eventId": "d4e5f6a7-b8c9-0123-defa-234567890123",
      "eventName": "notification_opened",
      "occurredAt": "2024-06-04T08:05:30Z",
      "source": "notification-service",
      "payload": {
        "notificationId": "55555555-5555-5555-5555-555555555555",
        "recipientId": "44444444-4444-4444-4444-444444444444",
        "channel": "push",
        "category": "offer_activity",
        "actionUrl": "kalynow://offers/11111111-1111-1111-1111-111111111111",
        "openedAt": "2024-06-04T08:05:30Z",
        "timeToOpenMs": 42000
      }
    }
  ]
}

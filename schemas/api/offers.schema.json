{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://contracts.kalynow.com/api/offers.schema.json",
  "title": "Offers API",
  "description": "JSON Schema definitions for the kalyNow Offers REST API.",
  "definitions": {
    "Money": {
      "type": "object",
      "required": ["amount", "currency"],
      "additionalProperties": false,
      "properties": {
        "amount": { "type": "number", "minimum": 0 },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "BRL"] }
      }
    },
    "Address": {
      "type": "object",
      "required": ["street", "city", "state", "country", "postalCode"],
      "additionalProperties": false,
      "properties": {
        "street": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "postalCode": { "type": "string" },
        "coordinates": {
          "type": "object",
          "required": ["latitude", "longitude"],
          "additionalProperties": false,
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        }
      }
    },
    "OfferImage": {
      "type": "object",
      "required": ["id", "url", "isPrimary"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "url": { "type": "string", "format": "uri" },
        "altText": { "type": "string" },
        "isPrimary": { "type": "boolean" }
      }
    },
    "Offer": {
      "type": "object",
      "required": ["id", "title", "description", "price", "status", "category", "sellerId", "images", "address", "tags", "viewCount", "reservationCount", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "title": { "type": "string", "minLength": 1, "maxLength": 255 },
        "description": { "type": "string" },
        "price": { "$ref": "#/definitions/Money" },
        "status": { "type": "string", "enum": ["draft", "active", "reserved", "sold", "expired", "cancelled"] },
        "category": { "type": "string", "enum": ["real_estate", "vehicle", "electronics", "furniture", "clothing", "services", "other"] },
        "sellerId": { "type": "string", "format": "uuid" },
        "images": { "type": "array", "items": { "$ref": "#/definitions/OfferImage" } },
        "address": { "$ref": "#/definitions/Address" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "viewCount": { "type": "integer", "minimum": 0 },
        "reservationCount": { "type": "integer", "minimum": 0 },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "CreateOfferRequest": {
      "type": "object",
      "required": ["title", "description", "price", "category", "images", "address"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 255 },
        "description": { "type": "string", "minLength": 1 },
        "price": { "$ref": "#/definitions/Money" },
        "category": { "type": "string", "enum": ["real_estate", "vehicle", "electronics", "furniture", "clothing", "services", "other"] },
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["url", "isPrimary"],
            "additionalProperties": false,
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "altText": { "type": "string" },
              "isPrimary": { "type": "boolean" }
            }
          }
        },
        "address": { "$ref": "#/definitions/Address" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    },
    "ReserveOfferRequest": {
      "type": "object",
      "required": ["buyerId"],
      "additionalProperties": false,
      "properties": {
        "buyerId": { "type": "string", "format": "uuid" },
        "durationSeconds": {
          "type": "integer",
          "minimum": 60,
          "default": 3600,
          "description": "Desired reservation duration in seconds."
        }
      }
    }
  }
}
